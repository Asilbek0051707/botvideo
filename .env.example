# =============================================================================
# AI YouTube Factory — environment configuration
# Copy to `.env` and fill in. Never commit `.env`.
# =============================================================================

# ---- App ----
APP_NAME="AI YouTube Factory"
ENV=development                      # development | staging | production
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-to-a-long-random-string
API_KEYS=devkey-change-me            # comma-separated keys accepted by the REST API
PUBLIC_BASE_URL=http://localhost:8000

# ---- Postgres ----
POSTGRES_USER=factory
POSTGRES_PASSWORD=factory
POSTGRES_DB=factory
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Built from the parts above by default; override to point at Supabase Postgres.
DATABASE_URL=postgresql+psycopg://factory:factory@postgres:5432/factory

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Storage ----
# Backend: local | minio | s3 | supabase
STORAGE_BACKEND=minio
STORAGE_BUCKET=factory
STORAGE_PUBLIC=true

# Local (dev) storage root (used when STORAGE_BACKEND=local)
LOCAL_STORAGE_DIR=/data/storage

# MinIO / S3-compatible (used when STORAGE_BACKEND in {minio,s3})
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_ENDPOINT=http://localhost:9000   # URL clients use to fetch objects

# Supabase (used when STORAGE_BACKEND=supabase; also gives you Postgres)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=factory

# ---- LLM (script / SEO agents) ----
LLM_PROVIDER=anthropic               # anthropic | openai | mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- TTS (voice agent) ----
TTS_PROVIDER=mock                    # elevenlabs | openai | mock
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=Rachel
OPENAI_TTS_VOICE=alloy

# ---- Text-to-Video (visual / render) ----
# mock  -> FFmpeg-generated clips, no GPU, runs anywhere (default for local dev)
# replicate -> hosted GPU API (no infra)
# gpu   -> local/remote CUDA worker running the model (RunPod / Vast.ai)
T2V_PROVIDER=mock
REPLICATE_API_TOKEN=
REPLICATE_T2V_MODEL=lightricks/ltx-video
# For T2V_PROVIDER=gpu
GPU_T2V_MODEL=Lightricks/LTX-Video
HF_TOKEN=

# ---- Stock footage / images (optional B-roll) ----
PEXELS_API_KEY=

# ---- Render defaults ----
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920                    # 9:16 Shorts
VIDEO_FPS=30
TARGET_DURATION_SEC=45
MAX_DURATION_SEC=60

# ---- Telegram bot ----
TELEGRAM_BOT_TOKEN=
ADMIN_ID=                            # your single Telegram numeric user ID (run /id on @userinfobot)
TELEGRAM_ADMIN_IDS=                  # legacy comma-separated IDs (superseded by ADMIN_ID)
TELEGRAM_USER_DAILY_LIMIT=5

# ---- Webhooks / notifications ----
WEBHOOK_SIGNING_SECRET=change-me

# ---- Monitoring ----
FLOWER_BASIC_AUTH=admin:admin
SENTRY_DSN=
