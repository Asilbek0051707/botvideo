{
  "$schema": "https://railway.com/railway.schema.json",
  "build":  { "builder": "DOCKERFILE", "dockerfilePath": "worker/Dockerfile" },
  "deploy": {
    "startCommand": "celery -A worker.celery_app.celery worker -Q default,render -l info --concurrency=2",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  },
  "variables": {
    "ENV": "production",
    "STORAGE_BACKEND": "supabase",
    "T2V_PROVIDER": "replicate",
    "DATABASE_URL": "${{ Postgres.DATABASE_URL }}",
    "REDIS_URL": "${{ Redis.REDIS_URL }}",
    "CELERY_BROKER_URL": "${{ Redis.REDIS_URL }}/1",
    "CELERY_RESULT_BACKEND": "${{ Redis.REDIS_URL }}/2",
    "ANTHROPIC_API_KEY": "set-me",
    "REPLICATE_API_TOKEN": "set-me",
    "SUPABASE_URL": "set-me",
    "SUPABASE_SERVICE_KEY": "set-me"
  }
}
