{
  "$schema": "https://railway.com/railway.schema.json",
  "build":  { "builder": "DOCKERFILE", "dockerfilePath": "telegram_bot/Dockerfile" },
  "deploy": {
    "startCommand": "python -m telegram_bot.bot",
    "restartPolicyType": "ALWAYS"
  },
  "variables": {
    "ENV": "production",
    "DATABASE_URL": "${{ Postgres.DATABASE_URL }}",
    "REDIS_URL": "${{ Redis.REDIS_URL }}",
    "CELERY_BROKER_URL": "${{ Redis.REDIS_URL }}/1",
    "CELERY_RESULT_BACKEND": "${{ Redis.REDIS_URL }}/2",
    "TELEGRAM_BOT_TOKEN": "set-me",
    "TELEGRAM_ADMIN_IDS": "set-comma-separated-ids"
  }
}
