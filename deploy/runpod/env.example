# Env vars for the RunPod GPU worker.
ENV=production
T2V_PROVIDER=gpu
GPU_T2V_MODEL=Lightricks/LTX-Video
HF_TOKEN=hf_...

# Reach the broker/db over the public internet:
REDIS_URL=rediss://default:PASSWORD@HOST:PORT/0
CELERY_BROKER_URL=rediss://default:PASSWORD@HOST:PORT/1
CELERY_RESULT_BACKEND=rediss://default:PASSWORD@HOST:PORT/2
DATABASE_URL=postgresql+psycopg://user:pass@HOST:PORT/factory?sslmode=require

# Upload artifacts to the same storage the API reads from:
STORAGE_BACKEND=supabase
SUPABASE_URL=https://YOUR.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Render defaults (vertical Shorts)
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
